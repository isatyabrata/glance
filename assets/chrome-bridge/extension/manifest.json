{
  "manifest_version": 3,
  "name": "Glance Chrome Bridge",
  "version": "0.10.2",
  "description": "Bridge Glance MCP server to your live Chrome via native messaging.",
  "key": "",
  "background": { "service_worker": "background.js" },
  "permissions": [
    "tabs",
    "tabGroups",
    "scripting",
    "debugger",
    "nativeMessaging",
    "alarms",
    "storage",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Glance",
    "default_popup": "popup.html"
  }
}
